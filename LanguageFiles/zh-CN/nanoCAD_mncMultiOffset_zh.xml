<?xml version="1.0" encoding="utf-8"?>
<ModPlus>
	<mncMultiOffset
		LocalName="多重偏移"
		Description="一次操作执行多个偏移">
		<h1>請輸入偏移量：</h1>
		<hint1>
			允許的字元:
			數字, -, =
			範例:
			數值:
			-25  -14  =-6  7  =3  25 -4
			將產生以下距離的偏移量:
			-25  -39  -6  7  3  32  -43
		</hint1>
		<msg1>請選擇要偏移的物件：</msg1>
		<e1>輸入錯誤</e1>
	</mncMultiOffset>
</ModPlus>